		font-size: 1rem;
	}

	.hero-image {
		position: relative;
		display: flex;
		justify-content: center;
	}

	.hero-image img {
		width: 100%;
		max-width: 380px;
		height: auto;
		aspect-ratio: 3/4;
		object-fit: cover;
		mask-image: radial-gradient(circle at center, black 45%, transparent 75%);
		-webkit-mask-image: radial-gradient(circle at center, black 45%, transparent 75%);
	}

	.services, .portfolio {
		padding: 5rem 0;
	}

	.section-tag {
		display: block;
		text-align: center;
		font-size: 0.75rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 2px;
		color: var(--primary);
		margin-bottom: 0.75rem;
	}

	section h2 {
		font-size: 2.2rem;
		font-weight: 800;
		text-align: center;
		margin-bottom: 0.5rem;
	}

	.section-subtitle {
		text-align: center;
		color: var(--text-muted);
		margin-bottom: 3rem;
		max-width: 500px;
		margin-left: auto;
		margin-right: auto;
	}

	.services-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5rem;
	}

	.card {
		background: var(--card);
		padding: 2rem;
		border-radius: 16px;
		border: 1px solid var(--border);
		transition: all 0.4s ease;
		position: relative;
		overflow: hidden;
	}

	.card::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 2px;
		background: linear-gradient(90deg, transparent, var(--primary), transparent);
		opacity: 0;
		transition: opacity 0.4s;
	}

	.card:hover {
		border-color: rgba(0, 230, 118, 0.3);
		transform: translateY(-6px);
		box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
	}

	.card:hover::before {
		opacity: 1;
	}

	.card-featured {
		border-color: rgba(0, 230, 118, 0.2);
		background: linear-gradient(135deg, rgba(0, 230, 118, 0.05) 0%, var(--card) 100%);
	}

	.card-number {
		font-size: 4rem;
		font-weight: 800;
		color: rgba(255, 255, 255, 0.03);
		position: absolute;
		top: 1rem;
		right: 1.5rem;
		line-height: 1;
	}

	.card-icon {
		width: 52px;
		height: 52px;
		background: rgba(0, 230, 118, 0.1);
		border-radius: 12px;
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--primary);
		margin-bottom: 1.25rem;
		transition: all 0.3s;
	}

	.card:hover .card-icon {
		background: var(--primary);
		color: var(--bg);
	}

	.card h3 {
		font-size: 1.15rem;
		margin-bottom: 0.5rem;
		font-weight: 700;
	}

	.card p {
		color: var(--text-muted);
		font-size: 0.9rem;
		line-height: 1.6;
		margin-bottom: 1.25rem;
	}

	.portfolio-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.75rem;
	}

	.portfolio-card {
		background: linear-gradient(160deg, rgba(30, 30, 30, 0.6) 0%, rgba(18, 18, 18, 0.8) 100%);
		border-radius: 24px;
		overflow: hidden;
		border: 1px solid rgba(255, 255, 255, 0.05);
		transition: all 0.6s cubic-bezier(0.23, 1, 0.32, 1);
		text-decoration: none;
		color: inherit;
		display: block;
		backdrop-filter: blur(20px);
		position: relative;
	}

	.portfolio-card::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 3px;
		background: linear-gradient(90deg, transparent, var(--primary), transparent);
		opacity: 0;
		transition: opacity 0.4s;
	}

	.portfolio-card:hover::before {
		opacity: 1;
	}

	.portfolio-card:hover {
		border-color: rgba(0, 230, 118, 0.25);
		transform: translateY(-12px);
		box-shadow: 
			0 30px 60px rgba(0, 0, 0, 0.6),
			0 0 40px rgba(0, 230, 118, 0.08),
			inset 0 1px 0 rgba(255, 255, 255, 0.08);
	}

	.portfolio-image {
		height: 230px;
		background: linear-gradient(135deg, #1a1a1a, #0d0d0d);
		position: relative;
		overflow: hidden;
	}

	.portfolio-image::before {
		content: '';
		position: absolute;
		inset: 0;
		background: radial-gradient(circle at 50% 0%, rgba(0, 230, 118, 0.1) 0%, transparent 50%);
		z-index: 1;
		opacity: 0;
		transition: opacity 0.4s;
	}

	.portfolio-card:hover .portfolio-image::before {
		opacity: 1;
	}

	.portfolio-image::after {
		content: '';
		position: absolute;
		inset: 0;
		background: linear-gradient(180deg, transparent 40%, rgba(0, 0, 0, 0.5) 100%);
		pointer-events: none;
		z-index: 1;
	}

	.portfolio-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: top center;
		transition: transform 0.7s cubic-bezier(0.23, 1, 0.32, 1), filter 0.5s;
	}

	.portfolio-card:hover .portfolio-image img {
		transform: scale(1.12);
		filter: brightness(1.1) contrast(1.05);
	}

	.portfolio-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(135deg, rgba(0, 230, 118, 0.95) 0%, rgba(0, 180, 70, 0.9) 100%);
		display: flex;
		align-items: center;
		justify-content: center;
		opacity: 0;
		transition: opacity 0.4s;
		z-index: 2;
	}

	.portfolio-card:hover .portfolio-overlay {
		opacity: 1;
	}

	.portfolio-overlay svg {
		color: var(--bg);
		width: 55px;
		height: 55px;
		transform: scale(0.4) rotate(-45deg);
		transition: transform 0.5s cubic-bezier(0.23, 1, 0.32, 1);
		filter: drop-shadow(0 8px 25px rgba(0, 0, 0, 0.4));
		background: rgba(255, 255, 255, 0.2);
		padding: 15px;
		border-radius: 50%;
		box-sizing: content-box;
	}

	.portfolio-card:hover .portfolio-overlay svg {
		transform: scale(1) rotate(0deg);
	}

	.portfolio-year {
		position: absolute;
		top: 1rem;
		left: 1rem;
		padding: 0.35rem 0.8rem;
		background: rgba(0, 0, 0, 0.75);
		color: var(--text);
		border-radius: 10px;
		font-size: 0.7rem;
		font-weight: 700;
		backdrop-filter: blur(15px);
		z-index: 3;
		border: 1px solid rgba(255, 255, 255, 0.12);
		letter-spacing: 1.5px;
		box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
	}

	.portfolio-info {
		padding: 1.75rem;
	}

	.portfolio-header {
		display: flex;
		align-items: center;
		gap: 0.7rem;
		margin-bottom: 0.6rem;
	}

	.portfolio-info h3 {
		font-size: 1.25rem;
		font-weight: 800;
		letter-spacing: -0.5px;
		background: linear-gradient(135deg, #fff 0%, rgba(255, 255, 255, 0.8) 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.portfolio-badge {
		padding: 0.25rem 0.7rem;
		background: linear-gradient(135deg, var(--primary) 0%, #00C853 100%);
		color: var(--bg);
		border-radius: 8px;
		font-size: 0.55rem;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 1.2px;
		box-shadow: 0 4px 15px rgba(0, 230, 118, 0.4);
		animation: pulse-badge 2s infinite;
	}

	.portfolio-badge-prototype {
		background: linear-gradient(135deg, #FF6B35, #FF8C42);
		box-shadow: 0 4px 15px rgba(255, 107, 53, 0.4);
		animation: none;
	}

	@keyframes pulse-badge {
		0%, 100% { box-shadow: 0 4px 15px rgba(0, 230, 118, 0.4); }
		50% { box-shadow: 0 4px 25px rgba(0, 230, 118, 0.6); }
	}

	.portfolio-info > p {
		color: var(--text-muted);
		font-size: 0.9rem;
		margin-bottom: 1.25rem;
		line-height: 1.7;
	}

	.portfolio-tech {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		margin-bottom: 1rem;
	}

	.tech-tag {
		padding: 0.3rem 0.7rem;
		background: rgba(0, 230, 118, 0.08);
		border: 1px solid rgba(0, 230, 118, 0.15);
		border-radius: 6px;
		font-size: 0.7rem;
		font-weight: 600;
		color: var(--primary);
		letter-spacing: 0.3px;
	}

	.portfolio-footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding-top: 1.25rem;
		border-top: 1px solid rgba(255, 255, 255, 0.06);
	}

	.tags {
		display: flex;
		gap: 0.5rem;
	}

	.tag {
		padding: 0.35rem 0.75rem;
		background: rgba(255, 255, 255, 0.05);
		color: rgba(255, 255, 255, 0.65);
		border-radius: 8px;
		font-size: 0.65rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 1px;
		border: 1px solid rgba(255, 255, 255, 0.08);
		transition: all 0.3s;
	}

	.portfolio-card:hover .tag {
		background: rgba(0, 230, 118, 0.1);
		color: var(--primary);
		border-color: rgba(0, 230, 118, 0.2);
	}

	.visit-btn {
		padding: 0.5rem 1.2rem;
		background: linear-gradient(135deg, #00C853 0%, #00E676 50%, #69F0AE 100%);
		color: #fff;
		border-radius: 10px;
		font-size: 0.8rem;
		font-weight: 700;
		transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
		box-shadow: 0 4px 20px rgba(0, 230, 118, 0.3);
		letter-spacing: 0.5px;
		position: relative;
		overflow: hidden;
	}

	.visit-btn::before {
		content: '';
		position: absolute;
		top: 0;
		left: -100%;
		width: 100%;
		height: 100%;
		background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
		transition: left 0.5s;
	}

	.portfolio-card:hover .visit-btn::before {
		left: 100%;
	}

	.portfolio-card:hover .visit-btn {
		box-shadow: 0 8px 30px rgba(0, 230, 118, 0.5);
		transform: translateX(5px);
	}

	.animate-on-scroll {
		opacity: 0;
		transform: translateY(30px);
		transition: all 0.6s ease;
	}

	.animate-on-scroll.visible {
		opacity: 1;
		transform: translateY(0);
	}

	.about {
		padding: 6rem 0;
	}

	.about-content {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 4rem;
		align-items: center;
	}

	.about-text h2 {
		text-align: left;
		margin-bottom: 1rem;
	}

	.about-text p {
		color: var(--text-muted);
		font-size: 1rem;
		line-height: 1.8;
		margin-bottom: 1.5rem;
	}

	.about-highlights {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		margin-top: 1.5rem;
	}

	.highlight-item {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		padding: 0.6rem 0;
		font-size: 0.9rem;
		color: rgba(255, 255, 255, 0.9);
	}

	.highlight-item svg {
		color: var(--primary);
		flex-shrink: 0;
	}

	.about-stats {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1rem;
	}

	.about-stat {
		text-align: center;
		padding: 2rem 1.5rem;
		background: linear-gradient(160deg, rgba(25, 25, 25, 0.9) 0%, rgba(15, 15, 15, 0.7) 100%);
		border-radius: 20px;
		border: 1px solid rgba(255, 255, 255, 0.06);
		transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
		position: relative;
		overflow: hidden;
		backdrop-filter: blur(10px);
	}

	.about-stat::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 3px;
		background: linear-gradient(90deg, transparent, var(--primary), transparent);
		opacity: 0;
		transition: opacity 0.3s;
	}

	.about-stat:hover {
		border-color: rgba(0, 230, 118, 0.3);
		transform: translateY(-5px);
		box-shadow: 0 10px 40px rgba(0, 230, 118, 0.15);
	}

	.about-stat:hover::before {
		opacity: 1;
	}

	.stat-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 50px;
		height: 50px;
		background: linear-gradient(135deg, rgba(0, 230, 118, 0.15) 0%, rgba(0, 200, 83, 0.05) 100%);
		border-radius: 14px;
		margin-bottom: 1rem;
		border: 1px solid rgba(0, 230, 118, 0.1);
	}

	.stat-icon svg {
		color: var(--primary);
	}

	.about-stat strong {
		display: block;
		font-size: 2.2rem;
		font-weight: 800;
		background: linear-gradient(135deg, #00C853, #00E676, #69F0AE);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		margin-bottom: 0.3rem;
	}

	.about-stat span {
		font-size: 0.85rem;
		color: var(--text-muted);
		font-weight: 500;
	}

	.cta {
		padding: 6rem 0;
		text-align: center;
		background: linear-gradient(160deg, rgba(30, 30, 30, 0.6) 0%, rgba(18, 18, 18, 0.8) 100%);
		margin: 0 1.5rem;
		border-radius: 32px;
		position: relative;
		overflow: hidden;
		border: 1px solid rgba(255, 255, 255, 0.05);
	}

	.cta-bg {
		position: absolute;
		inset: 0;
		overflow: hidden;
		pointer-events: none;
	}

	.cta-orb {
		position: absolute;
		border-radius: 50%;
		filter: blur(80px);
	}

	.cta-orb-1 {
		width: 400px;
		height: 400px;
		background: rgba(0, 230, 118, 0.12);
		top: -150px;
		right: -100px;
	}

	.cta-orb-2 {
		width: 300px;
		height: 300px;
		background: rgba(0, 230, 118, 0.08);
		bottom: -100px;
		left: -50px;
	}

	.cta-content {
		position: relative;
		z-index: 1;
		max-width: 600px;
		margin: 0 auto;
		padding: 0 1.5rem;
	}

	.cta h2 {
		font-size: 2.5rem;
		font-weight: 800;
		margin-bottom: 1rem;
		letter-spacing: -0.5px;
	}

	.cta-subtitle {
		color: var(--text-muted);
		margin-bottom: 2rem;
		font-size: 1.1rem;
		line-height: 1.7;
	}

	.cta-features {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0.75rem;
		margin-bottom: 2.5rem;
		text-align: left;
	}

	.cta-feature {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		padding: 0.85rem 1rem;
		background: linear-gradient(160deg, rgba(25, 25, 25, 0.8) 0%, rgba(15, 15, 15, 0.6) 100%);
		border: 1px solid rgba(255, 255, 255, 0.06);
		border-radius: 12px;
		font-size: 0.85rem;
		color: rgba(255, 255, 255, 0.95);
		transition: all 0.3s;
		backdrop-filter: blur(10px);
	}

	.cta-feature:hover {
		border-color: rgba(0, 230, 118, 0.25);
		background: linear-gradient(160deg, rgba(30, 30, 30, 0.9) 0%, rgba(20, 20, 20, 0.7) 100%);
		transform: translateY(-2px);
	}

	.cta-feature svg {
		color: var(--primary);
		flex-shrink: 0;
		filter: drop-shadow(0 0 6px rgba(0, 230, 118, 0.4));
	}

	.cta-guarantee {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		margin-top: 1.5rem;
		padding: 0.5rem 1rem;
		background: rgba(255, 255, 255, 0.04);
		border-radius: 50px;
		font-size: 0.75rem;
		color: var(--text-muted);
		border: 1px solid rgba(255, 255, 255, 0.06);
	}

	.cta-guarantee svg {
		color: var(--primary);
	}

	.process {
		padding: 6rem 0;
		text-align: center;
	}

	.process-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
		margin-top: 3rem;
	}

	.process-step {
		padding: 2rem;
		background: linear-gradient(160deg, rgba(25, 25, 25, 0.8) 0%, rgba(15, 15, 15, 0.6) 100%);
		border-radius: 20px;
		border: 1px solid rgba(255, 255, 255, 0.05);
		position: relative;
		transition: all 0.4s;
	}

	.process-step:hover {
		border-color: rgba(0, 230, 118, 0.2);
		transform: translateY(-5px);
		box-shadow: 0 10px 40px rgba(0, 230, 118, 0.1);
	}

	.step-number {
		position: absolute;
		top: 1rem;
		right: 1.5rem;
		font-size: 3rem;
		font-weight: 800;
		color: rgba(255, 255, 255, 0.03);
		line-height: 1;
	}

	.step-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 60px;
		height: 60px;
		background: linear-gradient(135deg, rgba(0, 230, 118, 0.15) 0%, rgba(0, 200, 83, 0.05) 100%);
		border-radius: 16px;
		margin-bottom: 1.25rem;
		border: 1px solid rgba(0, 230, 118, 0.1);
	}

	.step-icon svg {
		color: var(--primary);
	}

	.process-step h3 {
		font-size: 1.2rem;
		font-weight: 700;
		margin-bottom: 0.75rem;
	}

	.process-step p {
		color: var(--text-muted);
		font-size: 0.9rem;
		line-height: 1.6;
	}

	.typing-text {
		color: var(--primary);
		background: linear-gradient(135deg, #00C853, #00E676, #69F0AE);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.typing-cursor {
		color: var(--primary);
		animation: blink 1s infinite;
	}

	@keyframes blink {
		0%, 50% { opacity: 1; }
		51%, 100% { opacity: 0; }
	}

	.floating-whatsapp {
		position: fixed;
		bottom: 1.5rem;
		right: 1.5rem;
		width: 60px;
		height: 60px;
		background: linear-gradient(135deg, #00C853, #00E676, #69F0AE);
		color: #fff;
		border-radius: 50%;
		display: none;
		align-items: center;
		justify-content: center;
		box-shadow: 0 4px 25px rgba(0, 230, 118, 0.5);
		z-index: 90;
		transition: all 0.3s;
		animation: float-pulse 2s infinite;
	}

	.floating-whatsapp:hover {
		transform: scale(1.1);
		box-shadow: 0 8px 40px rgba(0, 230, 118, 0.7);
	}

	@keyframes float-pulse {
		0%, 100% { box-shadow: 0 4px 25px rgba(0, 230, 118, 0.5); }
		50% { box-shadow: 0 4px 35px rgba(0, 230, 118, 0.8); }
	}

	.mobile-cta-bar {
		display: none;
		position: fixed;
		bottom: 0;
		left: 0;
		right: 0;
		padding: 0.75rem 1.5rem;
		background: rgba(10, 10, 10, 0.95);
		backdrop-filter: blur(20px);
		border-top: 1px solid rgba(255, 255, 255, 0.05);
		z-index: 100;
	}

	.mobile-cta-btn {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		width: 100%;
		padding: 0.85rem;
		background: linear-gradient(135deg, #00C853, #00E676, #69F0AE);
		color: #fff;
		text-decoration: none;
		border-radius: 10px;
		font-size: 0.95rem;
		font-weight: 700;
		transition: all 0.3s;
	}

	.mobile-cta-btn:hover {
		background: linear-gradient(135deg, #00E676, #69F0AE, #B9F6CA);
		box-shadow: 0 4px 25px rgba(0, 230, 118, 0.5);
	}

	.animate-on-scroll {
		opacity: 0;
		transform: translateY(30px);
		transition: all 0.6s cubic-bezier(0.23, 1, 0.32, 1);
	}

	.animate-on-scroll.visible {
		opacity: 1;
		transform: translateY(0);
	}

	.process-step:nth-child(1) { transition-delay: 0s; }
	.process-step:nth-child(2) { transition-delay: 0.15s; }
	.process-step:nth-child(3) { transition-delay: 0.3s; }

	.portfolio-card:nth-child(1) { transition-delay: 0s; }
