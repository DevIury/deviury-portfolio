---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="DevIury - Web Designer profissional. Crio sites modernos, rápidos e otimizados para converter visitantes em clientes." />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta name="theme-color" content="#00E676" />
		<title>{title}</title>

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content="DevIury | Web Designer" />
		<meta property="og:description" content="Crio sites modernos, rápidos e otimizados para converter visitantes em clientes. Seu negócio merece presença digital de alto nível." />
		<meta property="og:url" content="https://deviury.com" />
		<meta property="og:image" content="https://deviury.com/og-image.png" />
		<meta property="og:locale" content="pt_BR" />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content="DevIury | Web Designer" />
		<meta name="twitter:description" content="Crio sites modernos, rápidos e otimizados para converter visitantes em clientes." />
		<meta name="twitter:image" content="https://deviury.com/og-image.png" />

		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
	</head>
	<body>
		<slot />
	</body>
</html>
<style is:global>
	* {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

	:root {
		--primary: #00E676;
		--primary-dark: #00C853;
		--bg-dark: #0a0a0a;
		--bg-card: #111111;
		--text-white: #ffffff;
		--text-gray: #a0a0a0;
		--border: #1a1a1a;
	}

	html {
		scroll-behavior: smooth;
	}

	body {
		font-family: 'Inter', sans-serif;
		background-color: var(--bg-dark);
		color: var(--text-white);
		line-height: 1.6;
	}
</style>
